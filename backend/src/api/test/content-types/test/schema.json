      "default": "medium",
      "enum": [
        "easy",
        "medium",
        "hard"
      ]
    },
    "is_published": {
      "type": "boolean",
      "default": false
    },
    "module_type": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "listening",
        "reading",
        "writing",
        "speaking"
      ]
    },
    "audio_url": {
      "type": "string"
    },
    "is_full_mock_test": {
      "type": "boolean",
      "default": false
    },
    "reading_passages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::reading-passage.reading-passage",
      "mappedBy": "test"
    },
    "listening_sections": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::listening-section.listening-section",
      "mappedBy": "test"
    },
    "writing_tasks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::writing-task.writing-task",
      "mappedBy": "test"
    },
    "speaking_topics": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::speaking-topic.speaking-topic",
      "mappedBy": "test"
    }
  }
}
