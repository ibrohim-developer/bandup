    },
    "listening_sections": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::listening-section.listening-section",
      "mappedBy": "test"
    },
    "writing_tasks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::writing-task.writing-task",
      "mappedBy": "test"
    },
    "speaking_topics": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::speaking-topic.speaking-topic",
      "mappedBy": "test"
    }
  }
